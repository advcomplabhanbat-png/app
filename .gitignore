# ──────────────────────────────────────────────
# Gradle / Spring Boot
# ──────────────────────────────────────────────
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# ──────────────────────────────────────────────
# Node / Capacitor
# ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Capacitor generates these from src/main/resources/static
# Don't commit — regenerated by `npx cap sync`
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json

# ──────────────────────────────────────────────
# Android
# ──────────────────────────────────────────────
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/captures/
android/local.properties
android/*.iml
android/app/*.iml
android/app/release/

# Don't commit built APKs (build locally)
*.apk
*.aab

# ──────────────────────────────────────────────
# IDE
# ──────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/
.vscode/
.settings/
.classpath
.project
.factorypath

# ──────────────────────────────────────────────
# OS
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────
# Logs / misc
